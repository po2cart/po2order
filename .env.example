# Database
DATABASE_URL="postgresql://user:password@localhost:5432/po2order"

# Redis
REDIS_URL="redis://localhost:6379"

# OpenAI
OPENAI_API_KEY="sk-..."

# Anthropic (optional, for Claude)
ANTHROPIC_API_KEY="sk-ant-..."

# Auth (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_..."
CLERK_SECRET_KEY="sk_..."

# AWS (for S3 document storage + SQS queues)
AWS_ACCESS_KEY_ID="..."
AWS_SECRET_ACCESS_KEY="..."
AWS_REGION="us-east-1"
AWS_S3_BUCKET="po2order-documents"
AWS_SQS_QUEUE_URL="..."
AWS_SQS_QUEUE_NAME="po2order-processing"

# Cloudflare (R2, Queues, email workers)
CLOUDFLARE_ACCOUNT_ID="..."
CLOUDFLARE_API_TOKEN="..."
CLOUDFLARE_R2_ACCESS_KEY_ID="..."
CLOUDFLARE_R2_SECRET_ACCESS_KEY="..."
CLOUDFLARE_R2_BUCKET="po2order-documents"
CLOUDFLARE_R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
CLOUDFLARE_QUEUE_NAME="po2order-processing"

# Email ingestion
INBOUND_EMAIL_DOMAIN="orders.po2order.com"

# API
API_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:3001"

